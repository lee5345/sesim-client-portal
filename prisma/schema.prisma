generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT_ADMIN
  FIRM_STAFF
  FIRM_ADMIN
}

enum SalaryType {
  ANNUAL
  MONTHLY
  DAILY
  HOURLY
}

enum SalaryBasis {
  GROSS
  NET
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  EXPORT
  LOGIN
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Company {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  businessNumber String?
  isActive       Boolean   @default(true)

  // Profile / registration info
  firmContactName            String?
  managesPayroll             Boolean?
  managesFourMajorInsurance  Boolean?
  workplaceManagementNumber  String?
  representativeName         String?
  companyContactName         String?
  companyContactTitle        String?
  phone                      String?
  mobile                     String?
  fax                        String?
  email                      String?
  businessAddress            String?
  taxOfficeName              String?
  taxOfficeContact           String?
  certificatePassword        String?
  workersCompPhone           String?
  workersCompFax             String?
  nhisPhone                  String?
  nhisFax                    String?
  npsPhone                   String?
  npsFax                     String?
  employmentCenterPhone      String?
  employmentCenterFax        String?
  retirementPensionContact   String?
  retirementPensionPhone     String?
  notes                      String?

  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users                User[]
  registrationRequests RegistrationRequest[]
  departments          Department[]

  newHires            NewHire[]
  terminations        Termination[]
  compensationChanges CompensationChange[]

  @@index([deletedAt])
}

model Department {
  id        String    @id @default(uuid()) @db.Uuid
  companyId String    @db.Uuid
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, deletedAt])
}

model User {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  email              String   @unique
  passwordHash       String
  role               UserRole
  companyId          String?  @db.Uuid
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdNewHires            NewHire[]            @relation("NewHireCreatedBy")
  createdTerminations        Termination[]        @relation("TerminationCreatedBy")
  createdCompensationChanges CompensationChange[] @relation("CompChangeCreatedBy")
  auditLogs                  AuditLog[]           @relation("AuditLogActor")
  reviewedRegistrationRequests RegistrationRequest[] @relation("RegistrationRequestReviewedBy")
  passwordSetupTokens        PasswordSetupToken[]

  @@index([companyId])
}

model RegistrationRequest {
  id          String                      @id @default(uuid()) @db.Uuid
  name        String
  email       String
  companyName String
  phone       String?
  note        String?
  status      RegistrationRequestStatus   @default(PENDING)
  companyId   String?                     @db.Uuid
  reviewedById String?                    @db.Uuid
  reviewedAt  DateTime?
  createdAt   DateTime                    @default(now())

  company    Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  reviewedBy User?    @relation("RegistrationRequestReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([email, status])
}

model PasswordSetupToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NewHire {
  id            String      @id @default(uuid()) @db.Uuid
  companyId     String      @db.Uuid
  name          String
  email         String
  rrnEncrypted  String
  rrnIv         String
  hireDate      DateTime
  department    String?
  salaryType    SalaryType
  salaryBasis   SalaryBasis
  salaryAmount  Int
  isContract    Boolean     @default(false)
  contractStart          DateTime?
  contractEnd            DateTime?
  nonTaxableAllowances   Json?
  bankName               String?
  accountNumber          String?
  phone                  String?
  notes                  String?
  deletedAt              DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   String      @db.Uuid

  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy User    @relation("NewHireCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model Termination {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @db.Uuid
  name            String
  rrnEncrypted    String
  rrnIv           String
  terminationDate DateTime
  reason          String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String    @db.Uuid

  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy User    @relation("TerminationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model CompensationChange {
  id                 String      @id @default(uuid()) @db.Uuid
  companyId          String      @db.Uuid
  name               String
  rrnEncrypted       String
  rrnIv              String
  salaryTypeBefore   SalaryType
  salaryBasisBefore  SalaryBasis
  salaryAmountBefore Int
  salaryTypeAfter    SalaryType
  salaryBasisAfter   SalaryBasis
  salaryAmountAfter  Int
  changeDate         DateTime
  deletedAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  createdById        String      @db.Uuid

  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy User    @relation("CompChangeCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([companyId, deletedAt])
}

model AuditLog {
  id        String      @id @default(uuid()) @db.Uuid
  actorId   String      @db.Uuid
  companyId String      @db.Uuid
  action    AuditAction
  tableName String
  recordId  String?
  payload   Json?
  createdAt DateTime    @default(now())

  actor User @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([companyId])
}
