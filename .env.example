## Neon Postgres (Prisma 7)
#
# From Neon Console → Connect:
# - Pooled  → DATABASE_URL  (hostname includes `-pooler`)
# - Direct  → DIRECT_URL     (no `-pooler` in hostname)
#
# prisma.config.ts uses DIRECT_URL for CLI/migrations.
# lib/db.ts uses DATABASE_URL (pooled) via @prisma/adapter-neon at runtime.
#
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js (JWT/session signing)
AUTH_SECRET=""

# Gmail SMTP (password setup emails)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# App URL for links in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"
